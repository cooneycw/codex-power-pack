# Codex Power Pack - Root Environment Variables
#
# Prefer AWS Secrets Manager for shared runtime secrets.
# AWS credentials may live here if no IAM role or shared AWS profile is available.
#
# Optional local overrides:
#   GEMINI_API_KEY=...
#   OPENAI_API_KEY=...
#   ANTHROPIC_API_KEY=...
#   WOODPECKER_URL=...
#   WOODPECKER_API_TOKEN=...

AWS_SECRET_NAME=codex-power-pack
AWS_API_KEYS_SECRET_NAME=codex_llm_apikeys
AWS_REGION=us-east-1
AWS_SECRETSMANAGER_TOKEN=change-me-sidecar-token
# Optional startup tuning for containers that fetch through the sidecar
AWS_SECRETSMANAGER_AGENT_ATTEMPTS=30
AWS_SECRETSMANAGER_AGENT_RETRY_DELAY=1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
# Optional when the host uses a non-default profile in ~/.aws/{config,credentials}
AWS_PROFILE=
